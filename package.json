{
  "name": "qface",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "pages:dev": "bun run build && wrangler pages dev dist",
    "db:migrate:local": "wrangler d1 migrations apply qface --local",
    "db:migrate:remote": "wrangler d1 migrations apply qface --remote",
    "check": "biome check . && tsc --noEmit",
    "check:content": "bun scripts/generate-questions.ts --check",
    "content:generate": "bun scripts/generate-questions.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/view": "^6.43.6",
    "@tanstack/react-router": "^1.170.18",
    "@uiw/codemirror-theme-github": "^4.25.11",
    "@uiw/react-codemirror": "^4.25.11",
    "lucide-react": "^1.25.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@cloudflare/workers-types": "^5.20260722.1",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "wrangler": "^4.113.0",
    "zod": "^4.4.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "bun@1.3.14"
}
